{% comment %}
  Product Media Carousel snippet
  - Uses single-view carousel with autoplay, arrows, dots, swipe, keyboard nav
  - Renders media through the existing 'product-media' snippet
{% endcomment %}

{% liquid
  assign medias = product.media
  assign enable_autoplay = enable_autoplay | default: true
  assign autoplay_speed = autoplay_speed | default: 5
  assign autoplay_speed_ms = autoplay_speed | times: 1000
  assign transition_duration = transition_duration | default: 450
  assign show_arrows = show_arrows | default: true
  assign show_dots = show_dots | default: true
  assign pause_on_hover = pause_on_hover | default: true
  assign media_fit = media_fit | default: 'cover'
  assign corner_radius = corner_radius | default: 16
  assign soft_shadow = soft_shadow | default: true
  assign aspect_ratio_value = aspect_ratio | default: 'square'
%}

<div
  id="pmc-{{ section.id }}"
  class="pmc"
  data-autoplay="{{ enable_autoplay }}"
  data-autoplay-speed="{{ autoplay_speed_ms }}"
  data-transition-duration="{{ transition_duration }}"
  data-pause-hover="{{ pause_on_hover }}"
  data-show-dots="{{ show_dots }}"
  aria-label="{{ 'products.product.media' | t }}"
>
  <style>
    /* ── PMC wrapper ── */
    #pmc-{{ section.id }} {
      --pmc-radius: {{ corner_radius }}px;
      --pmc-duration: {{ transition_duration }}ms;
      --pmc-ease: cubic-bezier(0.25, 0.1, 0.25, 1);
      --pmc-fit: {{ media_fit }};
      --pmc-shadow: {% if soft_shadow %}0 20px 50px rgba(0, 0, 0, 0.08), 0 10px 25px rgba(0, 0, 0, 0.05){% else %}none{% endif %};
      --pmc-aspect: {% if aspect_ratio_value == 'portrait' %}3 / 4{% else %}1 / 1{% endif %};
      /* Fixed viewport heights so the box never grows beyond these */
      --pmc-viewport-h: 340px;
      --pmc-viewport-h-md: 440px;
      --pmc-viewport-h-lg: 520px;
      /* Thumb column: fixed square size so 5 visible thumbnails fit */
      --pmc-thumb-size: 76px;
      --pmc-thumb-gap: 0.6rem;
      /* 5 thumbs + 4 gaps = 5*76 + 4*~10 = 420px → matches --pmc-viewport-h-lg */
      --pmc-thumbs-max-h: var(--pmc-viewport-h);
      background: #f9fafb;
      padding: 1.25rem;
      border-radius: var(--pmc-radius);
      box-shadow: var(--pmc-shadow);
      position: relative;
      /* Prevent ANY child from escaping the box */
      overflow: hidden;
      box-sizing: border-box;
      width: 100%;
    }

    /* ── Layout: thumbs left | viewport right ── */
    #pmc-{{ section.id }} .pmc__layout {
      display: grid;
      grid-template-columns: var(--pmc-thumb-size) 1fr;
      gap: 0.75rem;
      align-items: stretch;
      /* Height drives everything; children fill this */
      height: var(--pmc-viewport-h);
    }

    /* ── Thumbnail column ── */
    #pmc-{{ section.id }} .pmc__thumbs {
      display: flex;
      flex-direction: column;
      gap: var(--pmc-thumb-gap);
      /* Scroll when more than 5 thumbnails */
      overflow-y: auto;
      overflow-x: hidden;
      /* Exactly as tall as the viewport so the scroll area is well-defined */
      height: 100%;
      max-height: 100%;
      padding: 0.2rem;
      background: #fff;
      border-radius: calc(var(--pmc-radius) - 4px);
      box-shadow: inset 0 0 0 1px rgba(17, 17, 17, 0.05);
      scroll-behavior: smooth;
      box-sizing: border-box;
    }
    /* Hide scrollbar visually but keep it functional */
    #pmc-{{ section.id }} .pmc__thumbs::-webkit-scrollbar { width: 3px; }
    #pmc-{{ section.id }} .pmc__thumbs::-webkit-scrollbar-thumb { background: rgba(0,0,0,0.15); border-radius: 3px; }
    #pmc-{{ section.id }} .pmc__thumbs::-webkit-scrollbar-track { background: transparent; }

    #pmc-{{ section.id }} .pmc__thumb {
      border: none;
      padding: 0;
      background: none;
      /* Fixed square — never grow or shrink */
      flex: 0 0 var(--pmc-thumb-size);
      width: var(--pmc-thumb-size);
      height: var(--pmc-thumb-size);
      border-radius: calc(var(--pmc-radius) - 6px);
      overflow: hidden;
      cursor: pointer;
      position: relative;
      outline-offset: 2px;
      box-sizing: border-box;
    }
    #pmc-{{ section.id }} .pmc__thumb::after {
      content: '';
      position: absolute;
      inset: 0;
      border: 2px solid transparent;
      border-radius: inherit;
      transition: border-color 150ms ease, box-shadow 150ms ease;
      box-shadow: inset 0 0 0 1px rgba(17, 17, 17, 0.06);
      pointer-events: none;
    }
    #pmc-{{ section.id }} .pmc__thumb.is-active::after {
      border-color: #111;
      box-shadow: inset 0 0 0 1px #111;
    }
    #pmc-{{ section.id }} .pmc__thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    /* ── Main viewport ── */
    #pmc-{{ section.id }} .pmc__viewport {
      position: relative;
      overflow: hidden;
      border-radius: calc(var(--pmc-radius) - 4px);
      background: #fff;
      /* Fixed height – matches grid row height; aspect-ratio is NOT used here
         because it would fight with the fixed layout height */
      height: 100%;
      width: 100%;
      box-sizing: border-box;
    }

    /* ── Track: horizontally scrolling strip ── */
    #pmc-{{ section.id }} .pmc__track {
      display: flex;
      /* Track height must equal viewport height exactly */
      height: 100%;
      width: 100%;
      transition: transform var(--pmc-duration) var(--pmc-ease);
      will-change: transform;
    }

    /* ── Each slide ── */
    #pmc-{{ section.id }} .pmc__slide {
      flex: 0 0 100%;
      width: 100%;
      height: 100%;
      position: relative;
      overflow: hidden;
    }

    /* ── Media wrapper inside each slide ── */
    #pmc-{{ section.id }} .pmc__media {
      position: absolute;
      inset: 0;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    /* Direct children from product-media snippet */
    #pmc-{{ section.id }} .pmc__media > * {
      width: 100% !important;
      height: 100% !important;
      max-width: 100% !important;
      max-height: 100% !important;
      object-fit: var(--pmc-fit) !important;
      flex-shrink: 0;
    }

    /* Images */
    #pmc-{{ section.id }} .pmc__media img {
      position: static !important;
      display: block !important;
      width: 100% !important;
      height: 100% !important;
      max-width: 100% !important;
      max-height: 100% !important;
      object-fit: var(--pmc-fit) !important;
      object-position: center !important;
      padding: 0 !important;
    }

    /* Override any padding-top aspect-ratio hack on deferred-media */
    #pmc-{{ section.id }} .pmc__media .deferred-media,
    #pmc-{{ section.id }} .pmc__media deferred-media,
    #pmc-{{ section.id }} .pmc__media product-model {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      max-width: none !important;
      max-height: none !important;
      padding-top: 0 !important;
    }
    #pmc-{{ section.id }} .pmc__media .deferred-media__poster {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
    }
    #pmc-{{ section.id }} .pmc__media .deferred-media__poster img {
      position: static !important;
      width: 100% !important;
      height: 100% !important;
      object-fit: var(--pmc-fit) !important;
    }
    #pmc-{{ section.id }} .pmc__media video,
    #pmc-{{ section.id }} .pmc__media model-viewer,
    #pmc-{{ section.id }} .pmc__media iframe {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      object-fit: var(--pmc-fit) !important;
    }
    /* Neutralise the product-media-container padding-top aspect trick */
    #pmc-{{ section.id }} .pmc__media .product-media-container,
    #pmc-{{ section.id }} .pmc__media .media {
      position: absolute !important;
      inset: 0 !important;
      width: 100% !important;
      height: 100% !important;
      padding-top: 0 !important;
    }

    /* ── Arrows ── */
    #pmc-{{ section.id }} .pmc__arrows {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 0.75rem;
      pointer-events: none;
      z-index: 2;
    }
    #pmc-{{ section.id }} .pmc__arrow {
      pointer-events: auto;
      width: 38px;
      height: 38px;
      display: grid;
      place-items: center;
      border-radius: 50%;
      border: 1px solid rgba(255, 255, 255, 0.5);
      background: rgba(255, 255, 255, 0.72);
      color: #111;
      opacity: 0;
      transition: opacity 180ms ease;
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      flex-shrink: 0;
    }
    #pmc-{{ section.id }}:hover .pmc__arrow,
    #pmc-{{ section.id }} .pmc__arrow:focus-visible {
      opacity: 1;
    }
    #pmc-{{ section.id }} .pmc__arrow svg {
      width: 18px;
      height: 18px;
    }

    /* ── Dots ── */
    #pmc-{{ section.id }} .pmc__dots {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      margin-top: 0.875rem;
      flex-wrap: wrap;
    }
    #pmc-{{ section.id }} .pmc__dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.12);
      transition: all 180ms ease;
      border: none;
      padding: 0;
      cursor: pointer;
    }
    #pmc-{{ section.id }} .pmc__dot.is-active {
      width: 26px;
      background: #111;
    }
    #pmc-{{ section.id }} .pmc__dot:focus-visible {
      outline: 2px solid #111;
      outline-offset: 2px;
    }

    /* Touch devices: always show arrows */
    @media (hover: none) {
      #pmc-{{ section.id }} .pmc__arrow { opacity: 1; }
    }

    /* ── Medium screens (750 – 989px) ── */
    @media screen and (min-width: 750px) and (max-width: 989px) {
      #pmc-{{ section.id }} .pmc__layout {
        height: var(--pmc-viewport-h-md);
      }
    }

    /* ── Large screens (≥ 990px) ── */
    @media screen and (min-width: 990px) {
      #pmc-{{ section.id }} .pmc__layout {
        height: var(--pmc-viewport-h-lg);
      }
    }

    /* ── Mobile (< 750px): thumbs go below the viewport in a horizontal row ── */
    @media screen and (max-width: 749px) {
      #pmc-{{ section.id }} {
        padding: 0.875rem;
      }
      #pmc-{{ section.id }} .pmc__layout {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        height: auto;
      }
      #pmc-{{ section.id }} .pmc__viewport {
        /* On mobile use aspect-ratio instead of fixed height */
        height: auto;
        aspect-ratio: var(--pmc-aspect);
        min-height: 240px;
        width: 100%;
      }
      #pmc-{{ section.id }} .pmc__slide,
      #pmc-{{ section.id }} .pmc__track {
        /* Re-establish height context from the viewport's intrinsic size */
        height: 100%;
      }
      #pmc-{{ section.id }} .pmc__thumbs {
        flex-direction: row;
        overflow-x: auto;
        overflow-y: hidden;
        height: auto;
        max-height: none;
        width: 100%;
        padding: 0.2rem;
        scroll-snap-type: x mandatory;
      }
      #pmc-{{ section.id }} .pmc__thumbs::-webkit-scrollbar { height: 3px; width: auto; }
      #pmc-{{ section.id }} .pmc__thumb {
        flex: 0 0 64px;
        width: 64px;
        height: 64px;
        scroll-snap-align: start;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      #pmc-{{ section.id }} .pmc__track { transition: none; }
    }
  </style>

  {% if medias.size > 0 %}
    <div class="pmc__layout">
      <div class="pmc__thumbs" data-carousel-thumbs>
        {%- for media in medias -%}
          <button
            class="pmc__thumb{% if forloop.index0 == 0 %} is-active{% endif %}"
            type="button"
            data-thumb-index="{{ forloop.index0 }}"
            aria-label="{{ 'accessibility.go_to_slide' | t: slide: forloop.index }}"
            aria-current="{% if forloop.index0 == 0 %}true{% else %}false{% endif %}"
          >
            <img
              src="{{ media.preview_image | image_url: width: 200 }}"
              alt="{{ media.alt | escape }}"
              loading="lazy"
            >
          </button>
        {%- endfor -%}
      </div>
      <div class="pmc__viewport" data-carousel-viewport>
        <div class="pmc__track" data-carousel-track>
          {%- for media in medias -%}
            <div class="pmc__slide" data-index="{{ forloop.index0 }}" data-media-id="{{ media.id }}">
              <div class="pmc__media">
                {% render 'product-media', media: media, loop: true, variant_image: media.attached_to_variant? %}
              </div>
            </div>
          {%- endfor -%}
        </div>
        {% if show_arrows and medias.size > 1 %}
          <div class="pmc__arrows" aria-hidden="true">
            <button class="pmc__arrow" type="button" data-dir="prev" aria-label="{{ 'accessibility.previous' | t }}">
              <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M11.5 5 7 9.5l4.5 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
            <button class="pmc__arrow" type="button" data-dir="next" aria-label="{{ 'accessibility.next' | t }}">
              <svg viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8.5 5 13 9.5l-4.5 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </button>
          </div>
        {% endif %}
      </div>
    </div>

    {% if show_dots and medias.size > 1 %}
      <div class="pmc__dots" role="tablist" aria-label="{{ 'accessibility.slider_dots' | t }}">
        {%- for media in medias -%}
          <button
            class="pmc__dot{% if forloop.index0 == 0 %} is-active{% endif %}"
            data-dot-index="{{ forloop.index0 }}"
            role="tab"
            aria-label="{{ 'accessibility.go_to_slide' | t: slide: forloop.index }}"
            aria-current="{% if forloop.index0 == 0 %}true{% else %}false{% endif %}"
            type="button"
          ></button>
        {%- endfor -%}
      </div>
    {% endif %}
  {% else %}
    <div class="pmc__viewport" style="display:grid;place-items:center;">
      <p>{{ 'products.product.media' | t }} unavailable</p>
    </div>
  {% endif %}
</div>

<script>
  (() => {
    const section = document.getElementById('pmc-{{ section.id }}');
    if (!section) return;
    const viewport = section.querySelector('[data-carousel-viewport]');
    const track = section.querySelector('[data-carousel-track]');
    if (!track) return;
    const slides = Array.from(track.children);
    const dots = Array.from(section.querySelectorAll('[data-dot-index]'));
    const prevBtn = section.querySelector('[data-dir="prev"]');
    const nextBtn = section.querySelector('[data-dir="next"]');
    const thumbs = Array.from(section.querySelectorAll('[data-thumb-index]'));

    let index = 0;
    const total = slides.length;
    const autoplayEnabled = section.dataset.autoplay === 'true' && total > 1;
    const pauseOnHover = section.dataset.pauseHover === 'true';
    const autoplaySpeed = Number(section.dataset.autoplaySpeed) || 5000;
    const transitionDuration = Number(section.dataset.transitionDuration) || 450;
    let timer = null;
    let pointerStartX = 0;
    let pointerDiff = 0;
    let isPointerDown = false;

    const setTransition = (enabled) => {
      track.style.transition = enabled ? `transform ${transitionDuration}ms cubic-bezier(0.25, 0.1, 0.25, 1)` : 'none';
    };

    const updateUI = () => {
      slides.forEach((slide, i) => slide.classList.toggle('is-active', i === index));
      dots.forEach((dot, i) => {
        const active = i === index;
        dot.classList.toggle('is-active', active);
        dot.setAttribute('aria-current', active ? 'true' : 'false');
      });
      thumbs.forEach((thumb, i) => {
        const active = i === index;
        thumb.classList.toggle('is-active', active);
        thumb.setAttribute('aria-current', active ? 'true' : 'false');
        thumb.tabIndex = active ? 0 : -1;
        // Scroll the active thumb into view within its OWN container only.
        // scrollIntoView() scrolls the entire page — we must not use it.
        if (active) {
          const container = thumb.parentElement;
          if (!container) return;
          const isHorizontal = getComputedStyle(container).flexDirection === 'row';
          if (isHorizontal) {
            // Horizontal row (mobile): scroll container left so thumb is visible.
            const left = thumb.offsetLeft - container.offsetLeft;
            const right = left + thumb.offsetWidth;
            if (left < container.scrollLeft) {
              container.scrollLeft = left;
            } else if (right > container.scrollLeft + container.clientWidth) {
              container.scrollLeft = right - container.clientWidth;
            }
          } else {
            // Vertical column (desktop): scroll container top so thumb is visible.
            const top = thumb.offsetTop - container.offsetTop;
            const bottom = top + thumb.offsetHeight;
            if (top < container.scrollTop) {
              container.scrollTop = top;
            } else if (bottom > container.scrollTop + container.clientHeight) {
              container.scrollTop = bottom - container.clientHeight;
            }
          }
        }
      });
    };

    const goTo = (nextIndex, { skipTransition = false } = {}) => {
      if (!total) return;
      setTransition(!skipTransition);
      index = (nextIndex + total) % total;
      const offset = index * 100;
      track.style.transform = `translateX(-${offset}%)`;
      updateUI();
      resetTimer();
    };

    const next = () => goTo(index + 1);
    const prev = () => goTo(index - 1);

    const resetTimer = () => {
      if (!autoplayEnabled) return;
      clearInterval(timer);
      timer = setInterval(next, autoplaySpeed);
    };

    const pause = () => autoplayEnabled && clearInterval(timer);

    // Prevent mousedown on all carousel controls from moving page focus,
    // which would trigger the browser's native scroll-into-view on the page.
    const noFocusScroll = (e) => e.preventDefault();
    [prevBtn, nextBtn, ...dots, ...thumbs].forEach((el) => {
      if (el) el.addEventListener('mousedown', noFocusScroll);
    });

    if (nextBtn) nextBtn.addEventListener('click', () => next());
    if (prevBtn) prevBtn.addEventListener('click', () => prev());

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const target = Number(dot.dataset.dotIndex);
        goTo(target);
      });
    });

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const target = Number(thumb.dataset.thumbIndex);
        goTo(target);
      });
    });

    if (pauseOnHover && viewport) {
      viewport.addEventListener('mouseenter', pause);
      viewport.addEventListener('mouseleave', resetTimer);
    }

    // Keyboard navigation
    section.setAttribute('tabindex', '0');
    section.addEventListener('keydown', (event) => {
      if (event.key === 'ArrowRight') {
        event.preventDefault();
        next();
      }
      if (event.key === 'ArrowLeft') {
        event.preventDefault();
        prev();
      }
    });

    // Swipe / drag support
    const onPointerDown = (event) => {
      isPointerDown = true;
      pointerStartX = event.clientX || event.touches?.[0]?.clientX || 0;
      pointerDiff = 0;
      pause();
    };

    const onPointerMove = (event) => {
      if (!isPointerDown) return;
      const currentX = event.clientX || event.touches?.[0]?.clientX || 0;
      pointerDiff = currentX - pointerStartX;
    };

    const onPointerUp = () => {
      if (!isPointerDown) return;
      isPointerDown = false;
      const threshold = 50;
      if (pointerDiff > threshold) prev();
      else if (pointerDiff < -threshold) next();
      resetTimer();
    };

    viewport?.addEventListener('pointerdown', onPointerDown, { passive: true });
    viewport?.addEventListener('pointermove', onPointerMove, { passive: true });
    window.addEventListener('pointerup', onPointerUp);
    viewport?.addEventListener('touchstart', onPointerDown, { passive: true });
    viewport?.addEventListener('touchmove', onPointerMove, { passive: true });
    window.addEventListener('touchend', onPointerUp);

    setTransition(true);
    goTo(0, { skipTransition: true });
    resetTimer();

    // ── Expose the carousel API so external code can drive it ──────────────
    section._pmc = { goTo, getIndex: () => index };

    // ── Variant-to-carousel sync ───────────────────────────────────────────
    // constants.js and pubsub.js are loaded with `defer`, meaning they execute
    // after the HTML is parsed but before DOMContentLoaded fires. This inline
    // IIFE runs during HTML parsing — before defer scripts — so we must wait
    // for DOMContentLoaded before touching subscribe / PUB_SUB_EVENTS.
    const goToMediaId = (mediaId) => {
      if (!mediaId) { goTo(0); return; }
      const slide = track.querySelector(`[data-media-id="${mediaId}"]`);
      if (!slide) { goTo(0); return; }
      const targetIndex = Number(slide.dataset.index);
      if (!isNaN(targetIndex)) goTo(targetIndex);
    };

    let unsubscribeVariant;

    const initVariantSync = () => {
      // By now all defer scripts (constants.js, pubsub.js, product-info.js) have run.
      const eventName =
        (typeof PUB_SUB_EVENTS !== 'undefined' && PUB_SUB_EVENTS.variantChange) ||
        'variant-change';

      if (typeof subscribe === 'function') {
        unsubscribeVariant = subscribe(eventName, (payload) => {
          // product-info.js publishes: { data: { sectionId, html, variant } }
          const data = payload?.data || payload?.detail || payload;
          goToMediaId(data?.variant?.featured_media?.id);
        });
      }
    };

    // DOMContentLoaded fires after all defer scripts have executed.
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initVariantSync, { once: true });
    } else {
      // Page already parsed (e.g. theme editor section reload)
      initVariantSync();
    }

    // Cleanup when the theme editor unloads this section to avoid memory leaks.
    document.addEventListener('shopify:section:unload', (e) => {
      if (e.detail?.sectionId !== '{{ section.id }}') return;
      unsubscribeVariant?.();
      clearInterval(timer);
      window.removeEventListener('pointerup', onPointerUp);
      window.removeEventListener('touchend', onPointerUp);
    }, { once: false });
  })();
</script>
