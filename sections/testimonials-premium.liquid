{% liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
%}
<div class="premium-section page-width">
  <div class="section-header">
    {% if heading != blank %}<h2 class="h1">{{ heading }}</h2>{% endif %}
    {% if subheading != blank %}<p class="premium-subtext">{{ subheading }}</p>{% endif %}
  </div>
  <div class="testimonials-grid">
    {% for block in section.blocks %}
      <article class="testimonial-card" {{ block.shopify_attributes }}>
        <div class="testimonial-card__header">
          <div class="testimonial-card__avatar">
            {% if block.settings.avatar != blank %}
              <img src="{{ block.settings.avatar | image_url: width: 120 }}" loading="lazy" alt="{{ block.settings.name | escape }}">
            {% endif %}
          </div>
          <div>
            <div class="testimonial-card__name">{{ block.settings.name }}</div>
            <div class="testimonial-card__role">{{ block.settings.role }}</div>
          </div>
          <div class="testimonial-card__rating" aria-hidden="true">★★★★★</div>
        </div>
        <p class="testimonial-card__body">{{ block.settings.body }}</p>
      </article>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Testimonials premium",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "Loved by modern households"},
    {"type": "textarea", "id": "subheading", "label": "Subheading", "default": "Premium smart home and wellness gadgets customers can feel and trust."}
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {"type": "image_picker", "id": "avatar", "label": "Avatar"},
        {"type": "text", "id": "name", "label": "Name", "default": "Alex R."},
        {"type": "text", "id": "role", "label": "Role", "default": "Smart home enthusiast"},
        {"type": "textarea", "id": "body", "label": "Quote", "default": "The quality feels premium and the setup was effortless. My daily routines are smoother already."}
      ]
    }
  ],
  "presets": [
    {"name": "Testimonials premium", "blocks": [{"type": "testimonial"}, {"type": "testimonial"}, {"type": "testimonial"}]}
  ]
}
{% endschema %}
