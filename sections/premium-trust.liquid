{% comment %}
  Premium trust badges section
{% endcomment %}

{{ 'section-premium-product.css' | asset_url | stylesheet_tag }}

<section class="premium-benefits" id="premium-trust-{{ section.id }}">
  <div class="premium-section__heading">{{ section.settings.heading }}</div>
  <p class="premium-section__subtext">{{ section.settings.subtext }}</p>
  <div class="premium-benefits__grid">
    {%- for block in section.blocks -%}
      <div class="premium-benefits__item" {{ block.shopify_attributes }}>
        <div class="premium-benefits__icon">
          {%- if block.settings.icon != blank -%}
            <img src="{{ block.settings.icon | image_url: width: 64 }}" width="32" height="32" loading="lazy" alt="">
          {%- else -%}
            <span class="svg-wrapper">{{ 'icon-checkmark.svg' | inline_asset_content }}</span>
          {%- endif -%}
        </div>
        <p class="premium-benefits__title">{{ block.settings.title }}</p>
        <p class="premium-benefits__text">{{ block.settings.text }}</p>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Trust badges",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "Shop with confidence"},
    {"type": "text", "id": "subtext", "label": "Subtext", "default": "Secure checkout, fast dispatch, and dedicated support."}
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Badge",
      "settings": [
        {"type": "text", "id": "title", "label": "Title", "default": "Secure payments"},
        {"type": "text", "id": "text", "label": "Text", "default": "256-bit encrypted checkout"},
        {"type": "image_picker", "id": "icon", "label": "Icon (optional)"}
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Premium trust",
      "blocks": [
        {"type": "item", "settings": {"title": "Secure checkout", "text": "Encrypted payments for peace of mind"}},
        {"type": "item", "settings": {"title": "Fast shipping", "text": "Dispatched within 24-48 hours"}},
        {"type": "item", "settings": {"title": "Easy returns", "text": "30-day money-back promise"}},
        {"type": "item", "settings": {"title": "Support", "text": "Real humans ready to help"}}
      ]
    }
  ]
}
{% endschema %}
