{% liquid
  assign heading = section.settings.heading
%}
<div class="premium-section page-width">
  {% if heading != blank %}
    <div class="section-header" style="text-align:center; margin-bottom: 18px;">
      <h3 class="h2">{{ heading }}</h3>
    </div>
  {% endif %}
  <div class="stats-band">
    {% for block in section.blocks %}
      <div class="stats-band__item" {{ block.shopify_attributes }}>
        <div class="stats-band__value">{{ block.settings.value }}</div>
        <div class="stats-band__label">{{ block.settings.label }}</div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Stats band",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "Your premium upgrade is one step away"}
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {"type": "text", "id": "value", "label": "Value", "default": "10K+"},
        {"type": "text", "id": "label", "label": "Label", "default": "Happy smart homes"}
      ]
    }
  ],
  "presets": [
    {"name": "Stats band", "blocks": [{"type": "stat"}, {"type": "stat"}, {"type": "stat"}]}
  ]
}
{% endschema %}
