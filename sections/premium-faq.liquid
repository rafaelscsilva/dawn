{{ 'section-premium-product.css' | asset_url | stylesheet_tag }}

<section class="premium-faq" id="premium-faq-{{ section.id }}">
  <div class="premium-section__heading">{{ section.settings.heading }}</div>
  <p class="premium-section__subtext">{{ section.settings.subtext }}</p>
  <div class="premium-faq__items">
    {%- for block in section.blocks -%}
      <details {{ block.shopify_attributes }}>
        <summary>{{ block.settings.question }}</summary>
        <p>{{ block.settings.answer }}</p>
      </details>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Premium FAQ",
  "settings": [
    {"type": "text", "id": "heading", "label": "Heading", "default": "Questions answered"},
    {"type": "text", "id": "subtext", "label": "Subtext", "default": "Quick details on shipping, returns, and product use."}
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {"type": "text", "id": "question", "label": "Question", "default": "How fast do you ship?"},
        {"type": "textarea", "id": "answer", "label": "Answer", "default": "Orders leave our warehouse in 1-2 business days with tracked delivery."}
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium FAQ",
      "blocks": [
        {"type": "faq", "settings": {"question": "What is the return window?", "answer": "Try it for 30 days. If it is not a fit, start a return for a refund."}},
        {"type": "faq", "settings": {"question": "Do you offer support?", "answer": "Yes. Our support team responds within one business day."}},
        {"type": "faq", "settings": {"question": "Is it compatible with my setup?", "answer": "Check the specs above or chat with us to confirm compatibility."}}
      ]
    }
  ]
}
{% endschema %}
